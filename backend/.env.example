# Application Config
NODE_ENV=development
PORT=5000

# Database Config
DATABASE_URL=postgresql://postgres:postgres_secure_pass@localhost:5432/veya_db?schema=public

# JWT Security
JWT_SECRET=super_secret_jwt_sign_key_change_in_production
JWT_EXPIRES_IN=24h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Cloudinary Storage (For Portfolio Images - Phase 5)
CLOUDINARY_CLOUD_NAME=placeholder_cloud_name
CLOUDINARY_API_KEY=placeholder_api_key
CLOUDINARY_API_SECRET=placeholder_api_secret
